# RagVault 사내 개발 서버 환경변수
# 사용법:
#   cp .env.internal.example .env.internal
#   .env.internal 을 편집해서 실제 값 채우기 (.gitignore 에 포함됨)
#   docker compose -f docker-compose.internal.yml --env-file .env.internal up -d

# ── 사내 Ollama 서버 ─────────────────────────────────────────────────────────
# 사내 Ollama 서버 주소 (사내 IP 또는 hostname)
INTERNAL_OLLAMA_BASE_URL=http://<사내-ollama-ip>:11434

# 사내 서버에 올라가 있는 모델명
INTERNAL_CHAT_MODEL=qwen3:8b
# embedding 모델: 사내 Ollama 서버에서 `ollama pull bge-m3` 설치 필요
INTERNAL_EMBEDDING_MODEL=bge-m3
# vision 모델 없으면 일반 chat 모델로 대체 (이미지 기능 제한됨)
INTERNAL_VLM_MODEL=qwen3:8b

# ── 인증 시크릿 ──────────────────────────────────────────────────────────────
# `openssl rand -hex 24` 로 생성 (최소 15자 이상)
# 이 값이 BOOTSTRAP_API_KEY 로도 사용돼 rag-backend 최초 기동 시 DB에 자동 등록됨.
RAG_BACKEND_API_KEY=CHANGE_ME_sk-rag-your-secret-key
# `openssl rand -hex 32` 로 생성
WEBUI_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# 최초 슈퍼어드민 이메일 (rag_users 테이블에 자동 등록)
# Open WebUI에 이 이메일로 계정이 존재해야 로그인 가능
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com

# ── 데이터베이스 (pgvector) ──────────────────────────────────────────────────
# 사내 서버에 설치된 PostgreSQL (pgvector) 접속 정보
# 예) jdbc:postgresql://192.168.x.x:5432/ragdb
SPRING_DATASOURCE_URL=jdbc:postgresql://<pgvector-host>:5432/<db-name>
SPRING_DATASOURCE_USERNAME=raguser
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# ── 고객사 MySQL (외부 서버) ─────────────────────────────────────────────────
# binlog + GTID 활성화 여부 사전 확인 필요:
#   SHOW VARIABLES LIKE 'log_bin';        → ON
#   SHOW VARIABLES LIKE 'gtid_mode';      → ON
#   SHOW VARIABLES LIKE 'binlog_format';  → ROW
INTERNAL_MYSQL_HOST=<외부-mysql-ip-또는-hostname>
INTERNAL_MYSQL_PORT=3306
INTERNAL_MYSQL_DATABASE=customer_sample
INTERNAL_MYSQL_USERNAME=raguser
INTERNAL_MYSQL_PASSWORD=CHANGE_ME
