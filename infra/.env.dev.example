# ragvault 개발서버 환경변수 템플릿
# 복사 후 실제 값 입력: cp infra/.env.dev.example infra/.env.dev
# .env.dev 는 git에 커밋하지 않음

# ── pgvector ──────────────────────────────────────────────
POSTGRES_PASSWORD=
WIDGET_DB_PASSWORD=

# ── 챗 백엔드 (app-internal) ──────────────────────────────
SPRING_DATASOURCE_PASSWORD=      # POSTGRES_PASSWORD 와 동일하게 설정

# openssl rand -hex 32
RAG_AUTH_JWT_SECRET=

# openssl rand -base64 32
RAG_DATASOURCE_ENC_KEY=

BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@dev.local
BOOTSTRAP_INITIAL_PASSWORD=changeme123
RAG_BACKEND_API_KEY=dev-api-key-change-in-prod

# ── 위젯 백엔드 (app-widget) ──────────────────────────────
# openssl rand -hex 32
WIDGET_AUTH_JWT_SECRET=

# openssl rand -base64 32
WIDGET_ENCRYPTION_KEY=

WIDGET_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
WIDGET_ADMIN_CORS_ORIGINS=http://localhost:5173
WIDGET_ALLOWED_SITE_KEYS=pk_test_widget_dev

BOOTSTRAP_ADMIN_EMAIL=admin@widget.local
BOOTSTRAP_ADMIN_PASSWORD=changeme123
