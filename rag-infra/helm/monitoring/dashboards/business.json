{
  "title": "RAG 비즈니스 지표 대시보드",
  "uid": "rag-business",
  "refresh": "5m",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["rag", "business", "kpi"],
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "일별 질의 수 (RAG / SQL / HYBRID)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {}
        }
      },
      "options": {
        "orientation": "auto",
        "barWidth": 0.6,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (intent) (increase(rag_query_total{intent=~\"RAG|SQL|HYBRID\"}[1d]))",
          "legendFormat": "{{intent}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "PII 마스킹 발동 횟수 (경로별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (path) (increase(rag_pii_masked_total{path=~\".+\"}[1h]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "사용자별 사용량 Top 10",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "질의 수" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "user_id" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "질의 수", "desc": true }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, sum by (user_id) (increase(rag_query_total[1d])))",
          "legendFormat": "{{user_id}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "SQL 쿼리 실행 성공 / 실패율",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": {} }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "pie",
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(rag_sql_executed_total{status=\"success\"}[1d]))",
          "legendFormat": "성공",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(rag_sql_executed_total{status=\"error\"}[1d]))",
          "legendFormat": "실패",
          "refId": "B",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "의도 분류 정확도 (피드백 기반)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(rag_intent_feedback_correct_total[1d])) / sum(increase(rag_intent_feedback_total[1d]))",
          "legendFormat": "의도 분류 정확도",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "파일 처리 통계 (업로드 수 / OCR 성공률)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "OCR 성공률" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 0.8 },
                  { "color": "green", "value": 0.95 }
                ]
              }}
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(rag_file_upload_total[1d]))",
          "legendFormat": "파일 업로드 수",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(rag_ocr_success_total[1d])) / sum(increase(rag_ocr_total[1d]))",
          "legendFormat": "OCR 성공률",
          "refId": "B",
          "instant": true
        }
      ]
    }
  ]
}
