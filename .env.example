# =====================================================================
# docker-compose.dev.yml 환경 변수 템플릿
# 사용법: cp .env.example .env  →  .env 파일에 실제 값 입력 후 실행
# .env 는 .gitignore 에 포함되어 있어 Git 에 커밋되지 않습니다.
# =====================================================================

# ── 인증 시크릿 (필수 — 반드시 변경하세요) ─────────────────────────────
# RAG 백엔드 API 인증 키. 임의 문자열 생성: openssl rand -hex 24
RAG_BACKEND_API_KEY=CHANGE_ME_sk-rag-your-secret-key

# Open WebUI 세션 서명 키. 임의 문자열 생성: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# ── 로컬 개발 DB 비밀번호 (로컬 컨테이너 전용 — 실데이터 없음) ───────────
POSTGRES_PASSWORD=ragpassword
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_PASSWORD=ragpassword

# ── Spring Boot 프로파일 ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev
